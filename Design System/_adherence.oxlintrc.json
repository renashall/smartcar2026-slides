{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/blocks/**",
              "components/core/**",
              "components/lists/**",
              "components/media/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Rubik|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Rubik, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|icon|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|fullWidth|disabled|iconLeft|iconRight|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, fullWidth, disabled, iconLeft, iconRight, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Callout'] > JSXAttribute > JSXIdentifier[name!=/^(?:kind|title|icon|children|key|ref|className|style|children)$/]",
        "message": "<Callout> doesn't accept that prop. Declared props: kind, title, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:padding|elevation|interactive|accent|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: padding, elevation, interactive, accent, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='CheckListItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:text|checked|key|ref|className|style|children)$/]",
        "message": "<CheckListItem> doesn't accept that prop. Declared props: text, checked."
      },
      {
        "selector": "JSXOpeningElement[name.name='CodeBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:language|title|prompt|children|key|ref|className|style|children)$/]",
        "message": "<CodeBlock> doesn't accept that prop. Declared props: language, title, prompt, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconDescCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:symbol|title|text|glass|key|ref|className|style|children)$/]",
        "message": "<IconDescCard> doesn't accept that prop. Declared props: symbol, title, text, glass."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconListItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|text|key|ref|className|style|children)$/]",
        "message": "<IconListItem> doesn't accept that prop. Declared props: icon, title, text."
      },
      {
        "selector": "JSXOpeningElement[name.name='ImageFrame'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|alt|fit|background|radius|pad|shadow|key|ref|className|style|children)$/]",
        "message": "<ImageFrame> doesn't accept that prop. Declared props: src, alt, fit, background, radius, pad, shadow."
      },
      {
        "selector": "JSXOpeningElement[name.name='ImageFrame'] > JSXAttribute[name.name='fit'] > Literal[value!=/^(?:cover|contain)$/]",
        "message": "<ImageFrame> fit must be one of 'cover' | 'contain'."
      },
      {
        "selector": "JSXOpeningElement[name.name='InfoCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|badge|title|children|key|ref|className|style|children)$/]",
        "message": "<InfoCard> doesn't accept that prop. Declared props: eyebrow, badge, title, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='MaterialCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|alt|name|count|note|key|ref|className|style|children)$/]",
        "message": "<MaterialCard> doesn't accept that prop. Declared props: src, alt, name, count, note."
      },
      {
        "selector": "JSXOpeningElement[name.name='MiniChecklist'] > JSXAttribute > JSXIdentifier[name!=/^(?:items|onDark|divided|key|ref|className|style|children)$/]",
        "message": "<MiniChecklist> doesn't accept that prop. Declared props: items, onDark, divided."
      },
      {
        "selector": "JSXOpeningElement[name.name='NumberedListItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|body|key|ref|className|style|children)$/]",
        "message": "<NumberedListItem> doesn't accept that prop. Declared props: title, body."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScreenshotCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|alt|step|stepLabel|caption|background|key|ref|className|style|children)$/]",
        "message": "<ScreenshotCard> doesn't accept that prop. Declared props: src, alt, step, stepLabel, caption, background."
      },
      {
        "selector": "JSXOpeningElement[name.name='StepListItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|body|key|ref|className|style|children)$/]",
        "message": "<StepListItem> doesn't accept that prop. Declared props: title, body."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tier'] > JSXAttribute > JSXIdentifier[name!=/^(?:tag|label|key|ref|className|style|children)$/]",
        "message": "<Tier> doesn't accept that prop. Declared props: tag, label."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
